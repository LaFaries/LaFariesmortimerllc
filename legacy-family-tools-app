}

.wrapper{max-width:1100px;margin:auto;padding:50px 22px}
h1{font-family:"Cormorant Garamond",serif;color:var(--gold);font-size:40px;margin:0 0 12px}
.sub{color:var(--muted);margin-bottom:32px;font-size:14px;line-height:1.6}

.grid{
 display:grid;
 grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
 gap:22px;
 margin-bottom:40px;
}

.card{
 background:linear-gradient(180deg,rgba(20,23,32,.95),rgba(15,17,21,.92));
 border:1px solid var(--line);
 border-radius:22px;
 padding:24px;
 box-shadow:0 14px 40px rgba(0,0,0,.35);
}

.card h2{
 font-family:"Cormorant Garamond",serif;
 color:var(--gold);
 margin:0 0 10px;
 font-size:26px;
}

.card-desc{
 font-size:14px;
 color:var(--muted);
 line-height:1.5;
 margin-bottom:16px;
}

label{
 display:block;
 font-size:13px;
 color:rgba(248,246,241,.86);
 margin:14px 0 6px;
 font-weight:600;
}

input,textarea{
 width:100%;
 padding:12px;
 border-radius:12px;
 border:1px solid var(--line);
 background:#020617;
 color:#fff;
 outline:none;
}

input:focus,textarea:focus{
 border-color:rgba(218,184,92,.5);
}

textarea{min-height:120px;resize:vertical}

button{
 margin-top:12px;
 margin-right:8px;
 padding:11px 16px;
