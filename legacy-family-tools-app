*{box-sizing:border-box}

body{
 margin:0;
 font-family:Inter,system-ui;
 color:var(--ivory);
 background:
 radial-gradient(1200px 700px at 15% 10%, rgba(218,184,92,.10), transparent 60%),
 radial-gradient(900px 600px at 85% 20%, rgba(43,21,71,.25), transparent 60%),
